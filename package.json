{
  "name": "vibe-template-cf",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\" ",
    "dev:frontend": "pnpm --filter @vibe-template-cf/frontend dev",
    "dev:backend": "pnpm exec wrangler pages dev frontend/dist --kv your_kv --d1 your_db --binding PASSWORD=123456 --ip 0.0.0.0 --port 8788 --proxy 3000",
    "build": "pnpm --filter @vibe-template-cf/frontend build",
    "lint": "pnpm --filter @vibe-template-cf/frontend lint",
    "typecheck": "pnpm --filter @vibe-template-cf/frontend typecheck",
    "prepare": "husky",
    "ci-test": "concurrently -k -s first \"pnpm run dev:backend\" \"wait-on http://localhost:8788 && mocha --exit\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "mocha": "^10.6.0",
    "prettier": "^3.6.2",
    "wait-on": "^7.2.0",
    "wrangler": "^4.24.0"
  }
}
